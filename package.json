{
  "name": "ai-photography-assistant",
  "version": "0.1.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "check": "npm run typecheck && npm run lint && npm run test",
    "build:ios:dev": "eas build --profile development --platform ios",
    "build:android:dev": "eas build --profile development --platform android"
  },
  "dependencies": {
    "expo": "~57.0.6",
    "expo-asset": "~57.0.5",
    "expo-camera": "~57.0.3",
    "expo-dev-client": "~57.0.6",
    "expo-file-system": "~57.0.1",
    "expo-image-manipulator": "~57.0.4",
    "expo-image-picker": "~57.0.4",
    "expo-media-library": "~57.0.2",
    "lucide-react-native": "^1.23.0",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-svg": "15.15.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@expo/ngrok": "^4.1.3",
    "@types/react": "^19.2.17",
    "babel-preset-expo": "^57.0.2",
    "eslint": "^10.6.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}
