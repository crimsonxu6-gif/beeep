# Expo app. Use the computer LAN IP when testing on a physical phone.
EXPO_PUBLIC_ANALYZE_API_URL=http://192.168.1.10:8000/v1/analyze
EXPO_PUBLIC_ENABLE_MOCK=0
EXPO_PUBLIC_DEBUG_PANEL=0
EXPO_PUBLIC_SAMPLE_FPS=0.75
EXPO_PUBLIC_GUIDANCE_TRIGGER_MODE=manual
EXPO_PUBLIC_ENABLE_SECONDARY_GUIDANCE=0
EXPO_PUBLIC_ANALYSIS_IMAGE_SHORT_EDGE=768
EXPO_PUBLIC_ANALYSIS_JPEG_QUALITY=0.7
EXPO_PUBLIC_ANALYSIS_UPLOAD_MODE=multipart
EXPO_PUBLIC_ENABLE_ANALYSIS_FIXTURE=0
EXPO_PUBLIC_ANALYSIS_FIXTURE_SOURCE=bundled
EXPO_PUBLIC_ANALYSIS_API_MODE=live
EXPO_PUBLIC_ANALYSIS_DEBUG_API_URL=http://10.0.2.2:8000/v1/debug/analyze-response
EXPO_PUBLIC_VISION_TIMEOUT_MS=1000
EXPO_PUBLIC_GUIDANCE_TIMEOUT_MS=19000
EXPO_PUBLIC_GUIDANCE_EXPIRES_MS=2500
EXPO_PUBLIC_STABILITY_FRAMES=2
EXPO_PUBLIC_STABILITY_DEBOUNCE_MS=1800
EXPO_PUBLIC_CONFIDENCE_THRESHOLD=0.6

# Backend.
APP_ENV=development
GUIDANCE_ENGINE=rules
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006
DEBUG_ANALYZE_ENDPOINT_ENABLED=0
DEBUG_ANALYZE_DELAY_MS=2500
BEEEP_API_KEY=
MAX_IMAGE_BYTES=2097152
MAX_IMAGE_EDGE=1600
MAX_IMAGE_PIXELS=2000000
VISION_TIMEOUT_MS=1000
GUIDANCE_TIMEOUT_MS=17000
SHUTTERMUSE_SERVICE_URL=http://127.0.0.1:8100
SHUTTERMUSE_SERVICE_API_KEY=
SHUTTERMUSE_DEBUG_OUTPUT=0
SUBJECT_PREFLIGHT_ENABLED=1
SUBJECT_PREFLIGHT_CONFIDENCE=0.55
SUBJECT_PREFLIGHT_MIN_AREA=0.03
SUBJECT_PREFLIGHT_TIMEOUT_MS=800
SUBJECT_PREFLIGHT_BLOCKING=0
SUBJECT_PRESENCE_TTL_MS=1500
SUBJECT_MISSING_CONFIRM_FRAMES=3
SUBJECT_POSE_MIN_VISIBLE_KEYPOINTS=4
SUBJECT_POSE_MIN_VISIBILITY=0.35
SUBJECT_POSE_MIN_AREA=0.015
BBOX_SAFETY_MIN_AREA=0.12
BBOX_SAFETY_RATIO_TOLERANCE=0.20
SUBJECT_PREFLIGHT_CONFIRMATION_FRAMES=3
SUBJECT_PREFLIGHT_HOLD_MS=1500
SUBJECT_PREFLIGHT_STATE_TTL_MS=10000

# GPU model service. The Hugging Face checkpoint is already merged; LoRA is optional.
SHUTTERMUSE_REPO_PATH=/models/ShutterMuse
SHUTTERMUSE_MODEL_PATH=ShutterMuse/ShutterMuse
SHUTTERMUSE_LORA_PATH=
SHUTTERMUSE_DEVICE=cuda
SHUTTERMUSE_DEVICE_MAP=auto
SHUTTERMUSE_WARMUP_IMAGE=
SHUTTERMUSE_TRUST_REMOTE_CODE=0
SHUTTERMUSE_MERGE_LORA=1
SHUTTERMUSE_MAX_NEW_TOKENS=192
SHUTTERMUSE_INPUT_SHORT_EDGE=1024
SHUTTERMUSE_ATTENTION_IMPLEMENTATION=default
SHUTTERMUSE_EVAL_CAPTURE_RAW_OUTPUT=0
SHUTTERMUSE_RAW_OUTPUT_MAX_CHARS=4000
SHUTTERMUSE_GENERATION_MAX_TIME_MS=14000
SHUTTERMUSE_INFERENCE_TIMEOUT_MS=15000
SHUTTERMUSE_PROMPT_MODE=official
# official | official_bbox_first | official_prefill | beeep_json
SHUTTERMUSE_OFFICIAL_COORDINATES=norm1000
SHUTTERMUSE_REQUIRE_QUALITY_WARMUP=0
SHUTTERMUSE_AUTOLOAD=1
SHUTTERMUSE_LOAD_IN_4BIT=0
SHUTTERMUSE_CPU_OFFLOAD=0
SHUTTERMUSE_GPU_MAX_MEMORY=7GiB
SHUTTERMUSE_CPU_MAX_MEMORY=8GiB
SHUTTERMUSE_OFFLOAD_FOLDER=
