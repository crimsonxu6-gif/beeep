{
  "expo": {
    "name": "AI Photo Coach",
    "slug": "ai-photo-coach",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.crimson054.aiphotocoach",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera access is required for real-time photography guidance.",
        "NSPhotoLibraryUsageDescription": "Photo library access lets you choose photos to preview and analyze.",
        "NSPhotoLibraryAddUsageDescription": "Photo library access is required to save captured photos.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.crimson054.aiphotocoach",
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "d299e567-a87b-4c2f-a73e-7a4e3a2c6e15"
      }
    },
    "owner": "crimson054"
  }
}
